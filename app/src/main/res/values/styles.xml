<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Primärer, plastischer Button (Standard-Button) -->
    <style name="Widget.App.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <!-- Tint deaktivieren, damit unser eigenes Drawable sichtbar bleibt -->
        <item name="backgroundTint">@null</item>

        <!-- Hintergrund (Drawable mit Verlauf) -->
        <item name="android:background">@drawable/bg_primary_button</item>

        <!-- Text-Eigenschaften: Night-Mode-fähig über Farb-Resource -->
        <item name="android:textColor">@color/btn_primary_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>

        <!-- Höhe & Innenabstand (macht die Buttons schlanker) -->
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>

        <!-- Rundung & leichte Höhe -->
        <item name="cornerRadius">24dp</item>
        <item name="android:elevation">2dp</item>
        <item name="pressedTranslationZ">4dp</item>

        <!-- Ripple -->
        <item name="rippleColor">@color/btn_primary_ripple</item>

        <!-- Insets auf 0, damit oben/unten nichts zusätzlich draufkommt -->
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>


    <!-- Neuer Comic-Button mit „hochstehend / reingedrückt“-Effekt -->
    <style name="Widget.App.ComicButton" parent="Widget.MaterialComponents.Button">
        <!-- Kein Tint, damit unser eigenes Drawable (Selector) unverändert bleibt -->
        <item name="backgroundTint">@null</item>

        <!-- Unser Selector: normal + pressed (ohne Schatten) -->
        <item name="android:background">@drawable/bg_primary_button_comic</item>

        <!-- Text-Eigenschaften: Night-Mode-fähig -->
        <item name="android:textColor">@color/btn_primary_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>

        <!-- Größe / Innenabstand -->
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>

        <!-- 3D-Effekt kommt aus den Drawables, nicht aus Elevation -->
        <item name="android:elevation">0dp</item>
        <item name="pressedTranslationZ">0dp</item>

        <!-- Ripple-Effekt wie beim Primary-Button -->
        <item name="rippleColor">@color/btn_primary_ripple</item>
    </style>

</resources>
